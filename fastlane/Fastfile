default_platform(:ios)

platform :ios do
  desc "Build e upload para TestFlight"
  lane :beta do
    setup_ci if ENV['CI']

    api_key = app_store_connect_api_key(
      key_id: ENV["APPLE_API_KEY_ID"],
      issuer_id: ENV["APPLE_API_ISSUER_ID"],
      key_content: ENV["APPLE_API_KEY_BASE64"],
      is_key_content_base64: true
    )

    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s,
      xcodeproj: "ios/App/App.xcodeproj"
    )

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "lat.velvet.app" => "velvet_appstore"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build e upload para App Store"
  lane :release do
    setup_ci if ENV['CI']

    api_key = app_store_connect_api_key(
      key_id: ENV["APPLE_API_KEY_ID"],
      issuer_id: ENV["APPLE_API_ISSUER_ID"],
      key_content: ENV["APPLE_API_KEY_BASE64"],
      is_key_content_base64: true
    )

    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s,
      xcodeproj: "ios/App/App.xcodeproj"
    )

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store"
    )

    upload_to_app_store(
      api_key: api_key,
      submit_for_review: false,
      automatic_release: false,
      force: true
    )
  end
end
